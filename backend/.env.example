# Example Auth0 config for backend
AUTH0_DOMAIN=your-auth0-domain
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_SECRET=your-auth0-client-secret
# Where Auth0 should redirect after login (client callback)
AUTH0_REDIRECT_URI=http://localhost:5173/callback
# Where to send users after logout
AUTH0_POST_LOGOUT_REDIRECT=http://localhost:5173
# Frontend origin for credentialed requests
CLIENT_ORIGIN=http://localhost:5173
# Backend port
PORT=3000