# Shared environment example for client and backend
# Copy this file to .env and fill in your values

## Client
VITE_BACKEND_URL=http://localhost:3000
VITE_AUTH0_CALLBACK_URL=http://localhost:5173/callback

## Backend
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_CLIENT_ID=your-auth0-client-id
AUTH0_CLIENT_SECRET=your-auth0-client-secret
AUTH0_SECRET=a-long-random-string-at-least-32-chars
AUTH0_BASE_URL=http://localhost:3000
AUTH0_REDIRECT_URI=http://localhost:5173/callback
AUTH0_POST_LOGOUT_REDIRECT=http://localhost:5173
CLIENT_ORIGIN=http://localhost:5173
PORT=3000

## Database
# Local development:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gymreviews
# Docker (used automatically by docker-compose.yml):
# DATABASE_URL=postgresql://postgres:postgres@db:5432/gymreviews
# Production (Render):
# DATABASE_URL=postgresql://...render.